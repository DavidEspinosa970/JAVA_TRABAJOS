public class Producto {

    String nombre;
    double precioUnitario;
    int cantidad;

    public Producto(String nombre, double precioUnitario, int cantidad) {
        this.nombre = nombre;
        this.precioUnitario = precioUnitario;
        this.cantidad = cantidad;
    }

    public double calcularTotal() {
        return precioUnitario * cantidad;
    }
}

Main
import java.util.Scanner;

public class MainProducto {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Producto[] productos = new Producto[3];
        double totalGeneral = 0;
        for (int i = 0; i < productos.length; i++) {

            System.out.println("Producto " + (i + 1));
            System.out.print("Nombre: ");
            String nombre = sc.next();
            System.out.print("Precio Unitario: ");
            double precio = sc.nextDouble();
            System.out.print("Cantidad: ");
            int cantidad = sc.nextInt();
            productos[i] = new Producto(nombre, precio, cantidad);
        }
        for (int i = 0; i < productos.length; i++) {
            totalGeneral += productos[i].calcularTotal();
        }
        System.out.println("El total de todos los productos es: " + totalGeneral);
    }
}
